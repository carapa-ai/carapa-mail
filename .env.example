# Local proxy ports
SMTP_PORT=2525
IMAP_PROXY_PORT=1993
HTTP_PORT=3200
PUBLIC_HOSTNAME=host.docker.internal
BIND_HOST=0.0.0.0
ALLOW_INSECURE_AUTH=true

# TLS certificates (generated with mkcert)
# mkcert CA root is typically at ~/.local/share/mkcert/rootCA.pem
#TLS_CERT_PATH=./certs/localhost+2.pem
#TLS_KEY_PATH=./certs/localhost+2-key.pem

# Database
DB_TYPE=sqlite
# DATABASE_URL=postgres://user:pass@localhost:5432/carapamail

# AI filtering
AI_FEATURES_ENABLED=true
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
FILTER_CONFIDENCE_THRESHOLD=0.7
FILTER_TIMEOUT=30000
MAX_PARALLEL_AI_CALLS=1          # 1 = serial (safe for local models); increase for Anthropic API
AGENT_CHUNK_TOKENS=0             # 0 = no chunking. e.g. 4000 = split large emails into ~4000-token chunks

# Security & Behavior
AUTO_QUARANTINE=true            # false = log-only mode (passthrough)
INBOUND_SCAN=true               # false = disable inbound scanner
INBOUND_SCAN_INTERVAL=60000     # Polling fallback interval (ms)
DKIM_VERIFY=false               # true = penalize emails missing DKIM/SPF
STRIP_REMOTE_IMAGES=false       # true = block all remote images in HTML emails
PII_REDACTION=false             # Enable PII redaction on IMAP content

# Admin / Setup
CARAPA_MAIL_TOKEN=                 # Generate a secure token for admin login
ALLOW_SIGNUP=false
ALLOW_PROMPT_OVERRIDE=true
ALLOW_PROMPT_APPEND=true
LOG_LEVEL=warn                  # debug | info | warn | error

# Encryption
# CARAPA_MAIL_ENCRYPTION_KEY=               # 32-byte hex key (auto-generated if empty)

# External antivirus (optional)
# AV_COMMAND=clamscan --no-summary -

# MCP Server (Agent Access)
# MCP_ENABLED=false
# MCP_PORT=3466
# MCP_PUBLIC_URL=http://localhost:3466/mcp